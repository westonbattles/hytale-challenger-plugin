$Common = "Common.ui";
$Sounds = "Sounds.ui";
$Container = "Common/Container.ui";


@UnreadyLabel = (FontSize: 16, TextColor: #202626, RenderBold: true, RenderUppercase: true, HorizontalAlignment: Center, VerticalAlignment: Center, ShrinkTextToFit: true, MinShrinkTextToFitFontSize: 12);
@ButtonLabel = (FontSize: 16, TextColor: #bdcbd3, RenderBold: true, RenderUppercase: true, HorizontalAlignment: Center, VerticalAlignment: Center, ShrinkTextToFit: true, MinShrinkTextToFitFontSize: 12);

@Background = PatchStyle(TexturePath: "BossSelectBackground.png");
@BossSelectDefaultButtonBackground = PatchStyle(TexturePath: "BossSelect.png");
@BossSelectHoveredButtonBackground = PatchStyle(TexturePath: "BossSelect_Hovered.png");
@BossSelectPressedButtonBackground = PatchStyle(TexturePath: "BossSelect_Pressed.png");

@UnreadyDefaultButtonBackground = PatchStyle(TexturePath: "UnreadyButton.png");
@UnreadyHoveredButtonBackground = PatchStyle(TexturePath: "UnreadyButton_Hovered.png");
@UnreadyPressedButtonBackground = PatchStyle(TexturePath: "UnreadyButton_Pressed.png");

@DefaultDropdownBoxLabelStyle = LabelStyle(TextColor: #96a9be, RenderUppercase: true, VerticalAlignment: Center, FontSize: 15);
@DefaultDropdownBoxEntryLabelStyle = LabelStyle(...@DefaultDropdownBoxLabelStyle, TextColor: #b7cedd);
@DropdownBoxHeight = 32;

@DefaultDropdownBoxStyle = DropdownBoxStyle(
  DefaultBackground: (TexturePath: "Common/Dropdown.png", Border: 16),
  HoveredBackground: (TexturePath: "Common/DropdownHovered.png", Border: 16),
  PressedBackground: (TexturePath: "Common/DropdownPressed.png", Border: 16),
  DefaultArrowTexturePath: "Common/DropdownCaret.png",
  HoveredArrowTexturePath: "Common/DropdownCaret.png",
  PressedArrowTexturePath: "Common/DropdownPressedCaret.png",
  ArrowWidth: 13,
  ArrowHeight: 18,
  LabelStyle: (...@DefaultDropdownBoxLabelStyle, RenderBold: true, RenderUppercase: false, FontSize: 19),
  EntryLabelStyle: (...@DefaultDropdownBoxEntryLabelStyle, RenderUppercase: false),
  NoItemsLabelStyle: (...@DefaultDropdownBoxEntryLabelStyle, TextColor: #b7cedd(0.5)),
  SelectedEntryLabelStyle: (...@DefaultDropdownBoxEntryLabelStyle, RenderBold: true, RenderUppercase: false),
  HorizontalPadding: 8,
  PanelScrollbarStyle: $Common.@DefaultScrollbarStyle,
  PanelBackground: (TexturePath: "Common/DropdownBox.png", Border: 16),
  PanelPadding: 2,
  PanelAlign: Bottom,
  PanelOffset: 3,
  EntryHeight: 31,
  EntriesInViewport: 10,
  HorizontalEntryPadding: 7,
  HoveredEntryBackground: (Color: #0a0f17),
  PressedEntryBackground: (Color: #0f1621),
  Sounds: $Sounds.@DropdownBox,
  EntrySounds: $Sounds.@ButtonsLight,
  FocusOutlineSize: 1,
  FocusOutlineColor: #ffffff(0.4)
);

TabNavigation #MainTabs {
  Anchor: (Height: 62 + 4, Top: 293, Left: 525+174, Right: 0);
  Style: $Container.@IconOnlyTopTabsStyle;
  SelectedTab: "Home";


  TabButton #Home {
    Id: "Home";
    Icon: "Common/Icons/IconGeneralHome.png";
    IconSelected: "Common/Icons/IconGeneralHomeActivated.png";
  }

  TabButton #Settings {
    Id: "Settings";
    Icon: "Common/Icons/IconGeneralSettings.png";
    IconSelected: "Common/Icons/IconGeneralSettingsActivated.png";
  }
}

$Container.@DecoratedContainer {
  Anchor: (Width: 525, Height: 360);

  $Container.@Title #PageTitle {
    Anchor: (Top: -316, Left: 0);
    Text: "Main Menu:";
  }

  Group #HomePage {
    Anchor: (Top: 0, Left: 87.5, Width: 350, Height: 360);
    TextButton #ReadyButton{
      Anchor: (Top: 165, Left: 75, Width: 200, Height: 54);
      Text: "Ready Up";
      Style: (
        Default: (LabelStyle: @ButtonLabel, Background: @BossSelectDefaultButtonBackground),
        Hovered: (LabelStyle: @ButtonLabel, Background: @BossSelectHoveredButtonBackground),
        Pressed: (LabelStyle: @ButtonLabel, Background: @BossSelectPressedButtonBackground),
        Sounds: (
          Activate: (SoundPath: "Common/Sounds/RandomRoll.ogg", Volume: -2),
          MouseHover: (SoundPath: $Sounds.@ButtonsLightHover, Volume: 6)
        )
      );
    }
    TextButton #UnreadyButton{
      Anchor: (Top: 165, Left: 75, Width: 200, Height: 54);
      Text: "Unready";
      Style: (
        Default: (LabelStyle: @UnreadyLabel, Background: @UnreadyDefaultButtonBackground),
        Hovered: (LabelStyle: @UnreadyLabel, Background: @UnreadyHoveredButtonBackground),
        Pressed: (LabelStyle: @UnreadyLabel, Background: @UnreadyPressedButtonBackground),
        Sounds: (
          Activate: (SoundPath: "Common/Sounds/RandomRoll.ogg", Volume: -2),
          MouseHover: (SoundPath: $Sounds.@ButtonsLightHover, Volume: 6)
        )
      );
    }
  }

  Group #SettingsPage {
    Anchor: (Top: 0, Left: 87.5, Width: 350, Height: 360);

    DropdownBox #PlayerList {
      @Anchor = (Top: 115);

      Anchor: (...@Anchor, Width: 330, Height: 64);
      Style: @DefaultDropdownBoxStyle;
    }


    TextButton #RandomBossSelectButton{
      Anchor: (Top: 210, Left: 75, Width: 200, Height: 54);
      Text: "Random";
      Style: (
        Default: (LabelStyle: @ButtonLabel, Background: @BossSelectDefaultButtonBackground),
        Hovered: (LabelStyle: @ButtonLabel, Background: @BossSelectHoveredButtonBackground),
        Pressed: (LabelStyle: @ButtonLabel, Background: @BossSelectPressedButtonBackground),
        Sounds: (
          Activate: (SoundPath: "Common/Sounds/RandomRoll.ogg", Volume: -2),
          MouseHover: (SoundPath: $Sounds.@ButtonsLightHover, Volume: 6)
        )
      );
    }
  }
}

